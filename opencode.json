{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "small_model": "{env:OPENCODE_SMALL_MODEL}",
  "lsp": {
    "custom-dart": {
      "disabled": false,
      "command": [
        "fvm",
        "dart",
        "language-server",
        "--protocol=lsp"
      ],
      "extensions": [
        ".dart"
      ],
      "initialization": {
        "onlyAnalyzeProjectsWithOpenFiles": false,
        "suggestFromUnimportedLibraries": true,
        "closingLabels": true,
        "outline": true,
        "flutterOutline": true
      }
    },
    "dart": {
      "disabled": true
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "-y", "prettier", "--write", "$FILE"],
      "languages": ["json", "yaml", "markdown", "html"]
    },
    "dart": {
      "command": ["bash", "scripts/format-dart.sh", "$FILE"],
      "extensions": [".dart"]
    }
  },
  "mcp": {
    "dart": {
      "enabled": true,
      "type": "local",
      "command": [
        "fvm",
        "dart",
        "mcp-server",
        "--force-roots-fallback"
      ]
    },
    "pubdev": {
      "type": "local",
      "command": ["npx", "-y", "@devqxi/pubdev-mcp-server"],
      "enabled": true
    }
  }
}