{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "custom-dart": {
      "disabled": false,
      "command": ["fvm", "dart", "language-server", "--protocol=lsp"],
      "extensions": [".dart"],
      "initialization": {
        "onlyAnalyzeProjectsWithOpenFiles": false,
        "suggestFromUnimportedLibraries": true,
        "closingLabels": true,
        "outline": true,
        "flutterOutline": true
      }
    },
    "dart": {
      "disabled": true
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "-y", "prettier", "--write", "$FILE"],
      "extensions": [".json", ".yaml", ".md", ".html"]
    },
    "dart": {
      "command": ["bash", "scripts/format-dart.sh", "$FILE"],
      "extensions": [".dart"]
    }
  },
  "mcp": {
    "dart": {
      "enabled": true,
      "type": "local",
      "command": ["fvm", "dart", "mcp-server", "--force-roots-fallback"]
    },
    "pubdev": {
      "type": "local",
      "command": ["npx", "-y", "@devqxi/pubdev-mcp-server"],
      "enabled": true
    },
    "sonarqube": {
      "type": "local",
      "command": ["sonar", "run", "mcp"],
      "enabled": true
    }
  }
}
