{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "custom-dart": {
      "disabled": false,
      "command": ["fvm", "dart", "language-server", "--protocol=lsp"],
      "extensions": [".dart"],
      "initialization": {
        "onlyAnalyzeProjectsWithOpenFiles": false,
        "suggestFromUnimportedLibraries": true,
        "closingLabels": true,
        "outline": true,
        "flutterOutline": true
      }
    },
    "dart": {
      "disabled": true
    }
  },
  "formatter": {
    "prettier": {
      "command": ["npx", "-y", "prettier", "--write", "$FILE"],
      "extensions": [".json", ".yaml", ".md", ".html"]
    },
    "dart": {
      "command": ["bash", "scripts/format-dart.sh", "$FILE"],
      "extensions": [".dart"]
    }
  },
  "mcp": {
    "dart": {
      "enabled": true,
      "type": "local",
      "command": ["fvm", "dart", "mcp-server", "--force-roots-fallback"]
    },
    "pubdev": {
      "type": "local",
      "command": ["npx", "-y", "@devqxi/pubdev-mcp-server"],
      "enabled": true
    },
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--init",
        "--rm",
        "-i",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_TOKEN",
        "mcp/sonarqube@sha256:edbce6ea2e688afc0acee278bd583def95ea39569a0f26434099898bca003095"
      ],
      "environment": {
        "SONARQUBE_ORG": "auravibes-apps",
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}"
      }
    }
  }
}
